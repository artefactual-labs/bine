setup .bine.json

# Retrieves the project name.
bine config get project
cmp stdout ../project-name
! stderr .

# Retrieves the project name from TOML too.
setup .bine.toml
bine config get project
cmp stdout ../project-name
! stderr .

# Rejects invalid command.
! bine config
! stdout .
stderr 'config command requires a subcommand'

# Rejects invalid key.
! bine config get invalid
! stdout .
stderr 'unknown config key: invalid'

# Rejects missing arguments.
! bine config get
! stdout .
stderr 'config get requires one argument'

-- .bine.json --
{
	"project": "test-project",
	"bins": []
}
-- .bine.toml --
project = "test-project"

[[bins]]
name = "perpignan"
url = "https://github.com/sevein/perpignan"
version = "1.0.0"
asset_pattern = "{name}_{version}_{goos}_{goarch}"
-- project-name --
test-project
